@attribute [type: RenderModeInteractiveServer]

@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web;

@inject ProtectedLocalStorage ProtectedLocalStore
@inject NavigationManager NavigationManager
@inject WebPortalUserSessionStateContainer WebPortalUserSessionStateContainer
@inject BrowserService BrowserService

<label for="SearchText" class="form-label">Search</label>
<input type="text" class="form-control" id="SearchText" @bind="@SearchText" @oninput="@(async x => { await SearchTextChanged((string)x.Value); })" />

<JiwaAPIAutoQueryGrid @ref="CustomerListGrid" Model="JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Debtor_ListOR"
                      QueryType="JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Debtor_ListORQuery"
                      UseFilters="false"
                      AutoQuery="@v_Jiwa_Debtor_ListORQuery"
                      ShowPageNavigationHeader="true"
                      CompactNavigationButtons="@CompactNavigationButtons"
                      HiddenColumns=@(new List<String> {"DebtorID"})
                      CaptionMaps=@(new Dictionary<string, string> { ["AccountNo"] = "Account No." } )
                      AddSelectButtonColumn="false"
                      ItemSelectedCallbackMethod="@ItemSelected"
                      InitialSelectedItemMethod="@InitialSelectedItemMethod"
                      NoAuthenticationTokenCallbackMethod="@NoAuthenticationToken"
                      AuthType="AuthTypes.JiwaAPISessionId"
                      APIExceptionCallbackMethod="@APIException">
</JiwaAPIAutoQueryGrid>

@code {
    [Parameter]
    public EventCallback<JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Debtor_ListOR> ItemSelectedCallbackMethod { get; set; }    
    [Parameter]
    public EventCallback NoAuthenticationTokenCallbackMethod { get; set; }
    [Parameter]
    public EventCallback<Exception> APIExceptionCallbackMethod { get; set; }
    [Parameter]
    public bool CompactNavigationButtons { get; set; }

    private JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Debtor_ListORQuery v_Jiwa_Debtor_ListORQuery { get; set; }
    private JiwaAPIAutoQueryGrid<JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Debtor_ListOR, JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Debtor_ListORQuery> CustomerListGrid { get; set; }

    private string? statusMessage;

    private string? SearchText;    
    private CancellationTokenSource? CancellationTokenSource { get; set; } = new CancellationTokenSource();

    public void Dispose()
    {
        CancellationTokenSource?.Cancel();
        CancellationTokenSource?.Dispose();
    }

    private async Task SearchTextChanged(string NewValue)
    {   
        try
        {
            CancellationTokenSource?.Cancel();
            CancellationTokenSource?.Dispose();
        }
        catch (ObjectDisposedException)
        {
            // swallow if already disposed - we don't care
        }

        CancellationTokenSource = new CancellationTokenSource();

        SearchText = NewValue;
        v_Jiwa_Debtor_ListORQuery.Skip = 0;
        v_Jiwa_Debtor_ListORQuery.AccountNoContains = SearchText;
        v_Jiwa_Debtor_ListORQuery.NameContains = SearchText;
        if (string.IsNullOrWhiteSpace(SearchText))
        {
            v_Jiwa_Debtor_ListORQuery.LastSavedDateTimeGreaterThan = new System.DateTimeOffset(1800, 1, 1, 0, 0, 0, new TimeSpan(0, 0, 0)); // WHERE 1=0 is the default query WHERE clause for OR queries if no condition is provided, so we start off with this to cause some results to return initiall
        }
        else
        {
            v_Jiwa_Debtor_ListORQuery.LastSavedDateTimeGreaterThan = null;
        }

        await CustomerListGrid.ExecuteAutoQuery(CancellationTokenSource.Token);            
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        v_Jiwa_Debtor_ListORQuery = new JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Debtor_ListORQuery()
        {
            OrderBy = "AccountNo",
            Fields = "DebtorID,AccountNo,Name",
            Take = 12,
            LastSavedDateTimeGreaterThan = new System.DateTimeOffset(1800, 1, 1, 0, 0, 0, new TimeSpan(0, 0, 0)) // WHERE 1=0 is the default query WHERE clause for OR queries if no condition is provided, so we start off with this to cause some results to return initiall
        };
    }

    public JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Debtor_ListOR InitialSelectedItemMethod(List<JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Debtor_ListOR> Results)
    {
        if (Results != null && Results.Count > 0)
        {
            return Results.FirstOrDefault();
        }
        else
        {
            return null;
        }
    }

    public async Task ItemSelected(JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Debtor_ListOR item)
    {
        await ItemSelectedCallbackMethod.InvokeAsync(item);
    }

    public void NoAuthenticationToken()
    {
        NoAuthenticationTokenCallbackMethod.InvokeAsync();
    }

    public async Task APIException(Exception ex)
    {
        await APIExceptionCallbackMethod.InvokeAsync(ex);
    }
}
