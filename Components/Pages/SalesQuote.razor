        salesQuote = await SendToAPI<JiwaFinancials.Jiwa.JiwaServiceModel.SalesQuotes.SalesQuote>(salesQuoteGETRequest);

        if (salesQuote != null)
        {
            SelectedHistory = salesQuote.Histories[currentSnap.Value - 1];
        }
    }

