@page "/SalesQuote/{QuoteId}"
@attribute [type: RenderModeInteractiveServer]
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using ServiceStack;
@inject ProtectedLocalStorage ProtectedLocalStore
@inject NavigationManager NavigationManager
@inject WebPortalUserSessionStateContainer WebPortalUserSessionStateContainer
@inject BrowserService BrowserService
@using Microsoft.AspNetCore.WebUtilities

<PageTitle>Sales Quote</PageTitle>

@if (APIRequestInProgress)
{
    <div class="modal fade show" id="myModal" style="display:inline-flex" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0">
                <div class="spinner-border" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        </div>
    </div>
}

<StatusMessage Message="@statusMessage"/>

@if (AddingItem)
{
    <div class="relative">
        <JiwaInventoryAutoQueryModalSelectionDialog Title="Select Item" OnClose="@AddItemDialogClosed" />
    </div>
}

@if (EditingFreight)
{
    <div class="relative">
        <EditQuoteFreightModalDialog Title="Edit Freight" salesQuote="@salesQuote" SelectedHistory="@SelectedHistory" OnClose="@EditFreightDialogClosed" />
    </div>
}

@if (salesQuote != null)
{
    <div class="row">
        <div class="col-3">
            <label for="QuoteNo" class="form-label">Quote No.</label>
            <input type="text" class="form-control" id="QuoteNo" readonly placeholder="@salesQuote.QuoteNo">
        </div>
        <div class="col-6">
            <label for="Name" class="form-label">Name</label>
            <input type="text" class="form-control" id="Name" readonly placeholder="@salesQuote.DebtorName">
        </div>
        <div class="col-3 text-end">
            <a href="/SalesQuotePDF/@SelectedHistory.QuoteHistoryID" target="_blank" rel="noopener noreferrer">
                <button class="btn" style="background-color:transparent">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-printer" viewBox="0 0 16 16">
                        <path d="M2.5 8a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1" />
                        <path d="M5 1a2 2 0 0 0-2 2v2H2a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h1v1a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-1h1a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-1V3a2 2 0 0 0-2-2zM4 3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2H4zm1 5a2 2 0 0 0-2 2v1H2a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v-1a2 2 0 0 0-2-2zm7 2v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1" />
                    </svg>
                </button>
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-3">
            <label for="Date" class="form-label">Date</label>
            @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
            {
                <input type="text" class="form-control" id="Date" readonly placeholder="@salesQuote.InvoiceInitDate.Value.ToString(@BrowserService.DateFormat)">
            }
            else
            {                
                <input type="date" class="form-control" id="Date" value="@salesQuote.InvoiceInitDate.Value.ToString("yyyy-MM-dd")" @onchange="@(async (e) =>
                                                              {
                                                                await QuoteChanged(e, (dtoQuote) =>
                                                                    {
                                                                        dtoQuote.InvoiceInitDate = DateTime.ParseExact(e.Value.ToString(), "yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture); 
                                                                    });
                                                              })">
            }
        </div>
        <div class="col-3">
            <label for="OrderNo" class="form-label">Order No.</label>
            @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
            {
                <input type="text" class="form-control" id="OrderNo" readonly placeholder="@salesQuote.OrderNo">
            }
            else
            {
                <input type="text" class="form-control" id="OrderNo" value="@salesQuote.OrderNo" @onchange="async (e) =>
                                       {
                                        await QuoteChanged(e, (dtoQuote) => 
                                                { 
                                                    dtoQuote.OrderNo = e.Value.ToString(); 
                                                });
                                       }">
            }
        </div>
        <div class="col-3">
            <label for="Reference" class="form-label">Reference</label>            
            @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
            {
                <input type="text" class="form-control" id="Reference" readonly placeholder="@salesQuote.SOReference">
            }
            else
            {
                <input type="text" class="form-control" id="Reference" value="@salesQuote.SOReference" @onchange="async (e) => 
                { 
                    await QuoteChanged(e, (dtoQuote) =>
                        {
                            dtoQuote.SOReference = e.Value.ToString();
                        });
                }">
            }
        </div>
    </div>

    <div class="row">
    </div>

    <br />

    <div class="row">
        <div class="col-1">
            <label for="Currency" class="form-label">
                <img src="data:image/png;base64,@Convert.ToBase64String(Config.Currencies[salesQuote.CurrencyID].Picture)" width="30" height="20">
                @salesQuote.CurrencyShortName
            </label>
        </div>        
    </div>

    <br />

    <label>
        Snapshot:
        <select @onchange="SelectedHistoryChange" class="form-select form-select-lg mb-3">
            @foreach (JiwaFinancials.Jiwa.JiwaServiceModel.SalesQuotes.SalesQuoteHistory history in salesQuote.Histories)
            {
                if (history.QuoteHistoryID == SelectedHistory?.QuoteHistoryID)
                {
                    <option value="@history.QuoteHistoryID" selected>@history.Ref</option>
                }
                else
                {
                    <option value="@history.QuoteHistoryID">@history.Ref</option>
                }
            }
        </select>
    </label>

    <ul class="nav nav-tabs" id="detailsTab" role="tablist">
        <li class="nav-item" role="presentation">
            <a @onclick='(() => OnSelectTab("Items-tab"))' class=@String.Format("nav-link{0}", SelectedTabId=="Items-tab" ? " active": null) id="Items-tab" data-bs-toggle="tab" data-bs-target="#Items" type="button" role="tab" aria-controls="Items" aria-selected=@String.Format("nav-link{0}", SelectedTabId=="Items-tab" ? "true": "false")>Items</a>
        </li>
        <li class="nav-item" role="presentation">
            <a @onclick='(() => OnSelectTab("Shipping-tab"))' class=@String.Format("nav-link{0}", SelectedTabId=="Shipping-tab" ? " active": null) id="Shipping-tab" data-bs-toggle="tab" data-bs-target="#Shipping" type="button" role="tab" aria-controls="Shipping" aria-selected=@String.Format("nav-link{0}", SelectedTabId=="Shipping-tab" ? "true": "false")>Shipping</a>
        </li>        
    </ul>

    <div class="tab-content">
        <div class=@String.Format("tab-pane{0}", SelectedTabId=="Items-tab" ? " active": null) id="Items" role="tabpanel" aria-labelledby="Items-tab">
            <div class="table-responsive">
                <table class="table table-bordered table-striped small">
                    <thead>
                        <tr>
                            <th class="text-center">#</th>
                            <th>Part No.</th>                                        
                            <th>Description</th>
                            <th>Unit</th>
                            <th class="text-end">Quantity Ordered</th>
                            <th class="text-end">Price Ex</th>
                            <th class="text-end">Total Ex</th>
                            <th class="text-end">Tax</th>
                            <th class="text-end">Total Inc.</th>
                            @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider == "credentials")
                            {
                                <th class="text-center" width="50px"></th>
                            }
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (JiwaFinancials.Jiwa.JiwaServiceModel.SalesQuotes.SalesQuoteLine salesQuoteLine in SelectedHistory.Lines)
                        {
                            <tr class="align-middle">
                                @if (salesQuoteLine.CommentLine.Value)
                                {
                                    <td>@salesQuoteLine.ItemNo</td>                                    

                                    @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
                                    {
                                        <td colspan="9">@salesQuoteLine.CommentText</td>
                                    }
                                    else
                                    {
                                        <td colspan="8">
                                            <input type="text" class="form-control" id="CommentText"
                                                   value=@salesQuoteLine.CommentText
                                                   @onchange="async (e) =>
                                                    {
                                                                await QuoteLineChanged(e, salesQuoteLine.QuoteLineID, (line) =>
                                                                {
                                                                    line.CommentText = e.Value.ToString();
                                                                });
                                                    }">
                                        </td>
                                    }
                                }
                                else
                                {
                                    <td class="text-end">@salesQuoteLine.ItemNo</td>
                                    <td>@salesQuoteLine.PartNo</td>
                                    <td>@salesQuoteLine.Description</td>
                                    @if (@salesQuoteLine.UnitOfMeasure != null)
                                    {
                                        <td>@salesQuoteLine.UnitOfMeasure.Name</td>
                                    }
                                    else
                                    {
                                        <td>@salesQuoteLine.SKUUnitName</td>
                                    }

                                    @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
                                    {
                                        <td class="text-end">@Config.FormattedDecimals(@salesQuoteLine.QuantityOrdered, salesQuoteLine.QuantityDecimalPlaces)</td>
                                    }
                                    else
                                    {
                                        <td width="160px">
                                            <input type="number" class="form-control" id="QuantityOrdered" 
                                                    style="text-align: right;"
                                                    value="@Config.FormattedDecimals(@salesQuoteLine.QuantityOrdered, salesQuoteLine.QuantityDecimalPlaces)" 
                                                    step="@(Math.Pow(10, (double)-salesQuoteLine.QuantityDecimalPlaces))" 
                                                    min="0"
                                                    @onchange="async (e) =>
                                                    {
                                                        await QuoteLineChanged(e, salesQuoteLine.QuoteLineID, (dtoQuoteLine) => 
                                                        {
                                                            decimal value = 0;
                                                            decimal.TryParse(e.Value.ToString(), out value);
                                                            // We don't test the result of the decimal.TryPase - anything invalid is 0
                                                            dtoQuoteLine.QuantityOrdered = value;
                                                        });
                                                    }">
                                        </td>                                        
                                    }                                    

                                    @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
                                    {
                                        <td class="text-end">@Config.FormattedCurrency(@salesQuoteLine.FXDiscountedPrice, salesQuote.CurrencyID)</td>
                                    }
                                    else
                                    {
                                        <td width="160px">
                                            <input type="number" class="form-control" id="FXDiscountedPrice" 
                                                value="@Config.FormattedDecimals(@salesQuoteLine.FXDiscountedPrice, Config.CurrencyDecimals(salesQuote.CurrencyID), false)"
                                                   style="text-align: right;"
                                                step="@(Math.Pow(10, (double)-Config.CurrencyDecimals(salesQuote.CurrencyID)))"
                                                min="0"
                                                @onchange="async (e) =>
                                                {
                                                    await QuoteLineChanged(e, salesQuoteLine.QuoteLineID, (dtoQuoteLine) =>
                                                        {
                                                            decimal value = 0;
                                                            decimal.TryParse(e.Value.ToString(), out value);
                                                            // We don't test the result of the decimal.TryPase - anything invalid is 0
                                                            dtoQuoteLine.FXDiscountedPrice = value;
                                                        });
                                                }">
                                        </td>
                                    }

                                    <td class="text-end">@Config.FormattedCurrency(@salesQuoteLine.FXLineTotal - salesQuoteLine.FXTaxToCharge, @salesQuote.CurrencyID)</td>
                                    <td class="text-end">@Config.FormattedCurrency(@salesQuoteLine.FXTaxToCharge, salesQuote.CurrencyID)</td>
                                    <td class="text-end">@Config.FormattedCurrency(@salesQuoteLine.FXLineTotal, salesQuote.CurrencyID)</td>                                    
                                }

                                @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider == "credentials")
                                {
                                    <td class="text-center">
                                        <button @onclick="_ => DeleteQuoteLine(salesQuoteLine)" class="btn" style="background-color:transparent">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="red" class="bi bi-x-circle" viewBox="0 0 20 20">
                                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16" />
                                                <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708" />
                                            </svg>
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                        <tr class="align-middle">
                            <td colspan="6" class="text-end">Sub Total</td>
                            <td class="text-end">@Config.FormattedCurrency(SelectedHistory.Lines.Sum(x => x.FXLineTotal - x.FXTaxToCharge), salesQuote.CurrencyID)</td>
                            <td class="text-end">@Config.FormattedCurrency(SelectedHistory.Lines.Sum(x => x.FXTaxToCharge), salesQuote.CurrencyID)</td>
                            <td class="text-end">@Config.FormattedCurrency(SelectedHistory.Lines.Sum(x => x.FXLineTotal), salesQuote.CurrencyID)</td>
                            @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider == "credentials")
                            {
                                <td class="text-end"></td>
                            }
                        </tr>

                        <tr class="align-middle">
                        @if (salesQuote.FXCartage1ExGst != 0 || salesQuote.FXCartage1Gst != 0 || salesQuote.FXCartage2ExGst != 0 || salesQuote.FXCartage2Gst != 0 || salesQuote.FXCartage3ExGst != 0 || salesQuote.FXCartage3Gst != 0)
                        {                            
                                <td colspan="6" class="text-end">Freight</td>
                                <td class="text-end">@Config.FormattedCurrency(salesQuote.FXCartage1ExGst + salesQuote.FXCartage2ExGst + salesQuote.FXCartage3ExGst, salesQuote.CurrencyID)</td>
                                <td class="text-end">@Config.FormattedCurrency(salesQuote.FXCartage1Gst + salesQuote.FXCartage2Gst + salesQuote.FXCartage3Gst, salesQuote.CurrencyID)</td>
                                <td class="text-end">@Config.FormattedCurrency(salesQuote.FXCartage1ExGst + salesQuote.FXCartage1Gst + salesQuote.FXCartage2ExGst + salesQuote.FXCartage2Gst + salesQuote.FXCartage3ExGst + salesQuote.FXCartage3Gst, salesQuote.CurrencyID)</td>                                
                        }
                        else
                        {
                            // even if there is no cartage, display as blank to give a better visual appeal - space out the sub total and total                            
                            <td colspan="6" class="text-end">Freight</td>
                            <td class="text-end"></td>
                            <td class="text-end"></td>
                            <td class="text-end"></td>                           
                        }

                        @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider == "credentials")
                        {
                            <td class="text-center">
                                <button @onclick="_ => EditFreight()" class="btn" style="background-color:transparent">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 20 20">
                                        <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
                                        <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z" />
                                    </svg>
                                </button>
                            </td>
                        }
                        </tr>

                        <tr class="align-middle">
                            <td colspan="6" class="text-end">
                                <label for="CurrencyTotal" class="form-label">
                                    <img src="data:image/png;base64,@Convert.ToBase64String(Config.Currencies[salesQuote.CurrencyID].Picture)" width="30" height="20">
                                    @salesQuote.CurrencyShortName
                                </label>
                                Total
                            </td>
                            <td class="text-end">@Config.FormattedCurrency(SelectedHistory.Lines.Sum(x => x.FXLineTotal - x.FXTaxToCharge) + salesQuote.FXCartage1ExGst + salesQuote.FXCartage2ExGst + salesQuote.FXCartage3ExGst, salesQuote.CurrencyID)</td>
                            <td class="text-end">@Config.FormattedCurrency(SelectedHistory.Lines.Sum(x => x.FXTaxToCharge) + salesQuote.FXCartage1Gst + salesQuote.FXCartage2Gst + salesQuote.FXCartage3Gst, salesQuote.CurrencyID)</td>
                            <td class="text-end">@Config.FormattedCurrency(SelectedHistory.Lines.Sum(x => x.FXLineTotal) + salesQuote.FXCartage1ExGst + salesQuote.FXCartage2ExGst + salesQuote.FXCartage3ExGst + salesQuote.FXCartage1Gst + salesQuote.FXCartage2Gst + salesQuote.FXCartage3Gst, salesQuote.CurrencyID)</td>
                            @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider == "credentials")
                            {
                                <td class="text-end"></td>
                            }
                        </tr>
                    </tbody>
                </table>

                @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider == "credentials")
                {
                <button @onclick="(() => AddQuoteLine())" type="button" class="btn btn-success">
                    Add Item
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="-6 -6 48 48">
                        <circle cx="16" cy="16" r="14" style="stroke: white;stroke-width:2" fill="transparent" />
                        <line x1="16" y1="6" x2="16" y2="26" style="stroke: white;stroke-width:2" />
                        <line x1="6" y1="16" x2="26" y2="16" style="stroke: white;stroke-width:2" />
                    </svg>
                </button>
                <button @onclick="(() => AddQuoteCommentLine())" type="button" class="btn btn-success">
                    Add Comment
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="-6 -6 48 48">
                        <circle cx="16" cy="16" r="14" style="stroke: white;stroke-width:2" fill="transparent" />
                        <line x1="16" y1="6" x2="16" y2="26" style="stroke: white;stroke-width:2" />
                        <line x1="6" y1="16" x2="26" y2="16" style="stroke: white;stroke-width:2" />
                    </svg>
                </button>
                }
            </div>
        </div>

        <div class=@String.Format("tab-pane{0}", SelectedTabId=="Shipping-tab" ? " active": null) id="Addresses" role="tabpanel" aria-labelledby="Shipping-tab">
            <div class="d-grid gap-3">
                <div></div>
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Shipping Address</h5>

                        <div class="row">
                            <div class="col-3">
                                <label for="DeliveryAddressee" class="form-label">Addressee</label>
                                @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
                                {
                                    <input type="text" class="form-control" id="DeliveryAddressee" readonly placeholder="@salesQuote.DeliveryAddressee">
                                }
                                else
                                {
                                    <input type="text" class="form-control" id="DeliveryAddressee" value="@salesQuote.DeliveryAddressee" @onchange="async (e) =>
                                        {
                                           await QuoteChanged(e, (q) => { q.DeliveryAddressee = e.Value.ToString(); });
                                        }">
                                }

                            </div>
                            <div class="col-3">
                                <label for="DeliveryAddressContactName" class="form-label">Contact Name</label>
                                @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
                                {
                                    <input type="text" class="form-control" id="DeliveryAddressContactName" readonly placeholder="@salesQuote.DeliveryAddressContactName">
                                }
                                else
                                {
                                    <input type="text" class="form-control" id="DeliveryAddressContactName" value="@salesQuote.DeliveryAddressContactName" @onchange="async (e) =>
                                            {
                                               await QuoteChanged(e, (q) => { q.DeliveryAddressContactName = e.Value.ToString(); });
                                            }">
                                }

                            </div>
                        </div>

                        <div class="row">
                            <div class="col-3">
                                <label for="DeliveryAddress1" class="form-label">Address 1</label>
                                @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
                                {
                                    <input type="text" class="form-control" id="DeliveryAddress1" readonly placeholder="@salesQuote.DeliveryAddress1">
                                }
                                else
                                {
                                    <input type="text" class="form-control" id="DeliveryAddress1" value="@salesQuote.DeliveryAddress1" @onchange="async (e) =>
                                        {
                                            await QuoteChanged(e, (q) => { q.DeliveryAddress1 = e.Value.ToString(); });
                                        }">
                                }

                            </div>
                            <div class="col-3">
                                <label for="DeliveryAddress2" class="form-label">Address 2</label>
                                @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
                                {
                                    <input type="text" class="form-control" id="DeliveryAddress2" readonly placeholder="@salesQuote.DeliveryAddress2">
                                }
                                else
                                {
                                    <input type="text" class="form-control" id="DeliveryAddress2" value="@salesQuote.DeliveryAddress2" @onchange="async (e) =>
                                        {
                                            await QuoteChanged(e, (q) => { q.DeliveryAddress2 = e.Value.ToString(); });
                                        }">
                                }
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-3">
                                <label for="DeliveryAddressState" class="form-label">State</label>
                                @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
                                {
                                    <input type="text" class="form-control" id="DeliveryAddressState" readonly placeholder="@salesQuote.DeliveryAddressState">
                                }
                                else
                                {
                                    <input type="text" class="form-control" id="DeliveryAddressState" value="@salesQuote.DeliveryAddressState" @onchange="async (e) =>
                                        {
                                            await QuoteChanged(e, (q) => { q.DeliveryAddressState = e.Value.ToString(); });
                                        }">
                                }
                            </div>
                            <div class="col-3">
                                <label for="DeliveryAddressSuburb" class="form-label">Suburb</label>
                                @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
                                {
                                    <input type="text" class="form-control" id="DeliveryAddressSuburb" readonly placeholder="@salesQuote.DeliveryAddressSuburb">
                                }
                                else
                                {
                                    <input type="text" class="form-control" id="DeliveryAddressSuburb" value="@salesQuote.DeliveryAddressSuburb" @onchange="async (e) =>
                                        {
                                                                                        await QuoteChanged(e, (q) => { q.DeliveryAddressSuburb = e.Value.ToString(); });
                                        }">
                                }
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-3">
                                <label for="DeliveryAddressPostcode" class="form-label">Postcode</label>
                                @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
                                {
                                    <input type="text" class="form-control" id="DeliveryAddressPostcode" readonly placeholder="@salesQuote.DeliveryAddressPostcode">
                                }
                                else
                                {
                                    <input type="text" class="form-control" id="DeliveryAddressPostcode" value="@salesQuote.DeliveryAddressPostcode" @onchange="async (e) =>
                                        {
                                            await QuoteChanged(e, (q) => { q.DeliveryAddressPostcode = e.Value.ToString(); });
                                        }">
                                }
                            </div>
                            <div class="col-3">
                                <label for="DeliveryAddressCountry" class="form-label">Country</label>
                                @if (WebPortalUserSessionStateContainer.WebPortalUserSession.AuthProvider != "credentials")
                                {
                                    <input type="text" class="form-control" id="DeliveryAddressCountry" readonly placeholder="@salesQuote.DeliveryAddressCountry">
                                }
                                else
                                {
                                    <input type="text" class="form-control" id="DeliveryAddressCountry" value="@salesQuote.DeliveryAddressCountry" @onchange="async (e) =>
                                        {
                                            await QuoteChanged(e, (q) => { q.DeliveryAddressCountry = e.Value.ToString(); });
