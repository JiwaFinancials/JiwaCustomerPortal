            else
            {
                statusMessage = webServiceException.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
        finally
        {
            APIRequestInProgress = oldAPIRequestInProgress;
        }

        return default(TResponse);
    }
