    private async Task EnsureSelectedProductPicture(JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Inventory_Item_ListOR product)
    {
        if (product == null || string.IsNullOrWhiteSpace(product.InventoryID))
        {
            return;
        }

        if (product.Picture != null && product.Picture.Length > 0)
        {
            ProductPictureCache[product.InventoryID] = product.Picture;
            return;
        }

        if (ProductPictureCache.TryGetValue(product.InventoryID, out byte[]? cachedPicture))
        {
            product.Picture = cachedPicture ?? Array.Empty<byte>();
            return;
        }

        Task<byte[]?> loadTask;
        if (!ProductPictureLoadTasks.TryGetValue(product.InventoryID, out loadTask))
        {
            loadTask = LoadPictureFromInventoryEndpoint(product.InventoryID);
            ProductPictureLoadTasks[product.InventoryID] = loadTask;
        }

        byte[]? picture;
        try
        {
            picture = await loadTask;
        }
        finally
        {
            ProductPictureLoadTasks.Remove(product.InventoryID);
        }

        ProductPictureCache[product.InventoryID] = picture;
        product.Picture = picture ?? Array.Empty<byte>();
    }

    private async Task<byte[]?> LoadPictureFromInventoryEndpoint(string inventoryId)
    {
        JiwaFinancials.Jiwa.JiwaServiceModel.InventoryPictureGETRequest pictureRequest = new JiwaFinancials.Jiwa.JiwaServiceModel.InventoryPictureGETRequest()
        {
            InventoryID = inventoryId
        };

        APIRequestInProgressCount++;
        try
        {
            return await JiwaAPI.GetAsync<byte[]>(pictureRequest, WebPortalUserSessionStateContainer.WebPortalUserSession.Id, null);
        }
        catch (ServiceStack.WebServiceException webServiceException)
        {
            if (webServiceException.StatusCode == 401)
            {
                // We are either not authenticated, or our token we have expired, go log on - but first clear any session info as it's no good no more.
                WebPortalUserSessionStateContainer.SetWebPortalUserSession(null);
                NavigationManager.NavigateTo($"User/SignIn?returnUrl={NavigationManager.Uri}");
            }
            else
            {
                statusMessage = webServiceException.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
        finally
        {
            APIRequestInProgressCount--;
        }

        return null;
    }

    private async Task ExportPriceListCsv()
    {
        if (FilteredProducts.Count == 0)
        {
            return;
        }

        StringBuilder csv = new();
        csv.AppendLine("PartNo,Description,Classification,Category1,Category2,Category3,AvailableStock,SellPrice,RRPPrice");

        foreach (JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Inventory_Item_ListOR product in FilteredProducts)
        {
            csv.Append(EscapeCsv(product.PartNo));
            csv.Append(',');
            csv.Append(EscapeCsv(product.Description));
            csv.Append(',');
            csv.Append(EscapeCsv(product.ClassificationDescription));
            csv.Append(',');
            csv.Append(EscapeCsv(product.Category1Description));
            csv.Append(',');
            csv.Append(EscapeCsv(product.Category2Description));
            csv.Append(',');
            csv.Append(EscapeCsv(product.Category3Description));
            csv.Append(',');
            csv.Append((product.AvailableStock ?? 0m).ToString(CultureInfo.InvariantCulture));
            csv.Append(',');
            csv.Append((product.SellPrice ?? 0m).ToString(CultureInfo.InvariantCulture));
            csv.Append(',');
            csv.Append((product.RRPPrice ?? 0m).ToString(CultureInfo.InvariantCulture));
            csv.AppendLine();
        }

        string debtorName = WebPortalUserSessionStateContainer.WebPortalUserSession?.DebtorName ?? "PriceList";
        string safeDebtorName = string.Join("_", debtorName.Split(Path.GetInvalidFileNameChars(), StringSplitOptions.RemoveEmptyEntries));
        string fileName = $"{safeDebtorName}_PriceList_{DateTime.Now:yyyyMMdd}.csv";

        byte[] data = Encoding.UTF8.GetBytes(csv.ToString());
        await using MemoryStream stream = new(data);
        using DotNetStreamReference streamRef = new(stream: stream);

        await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
    }

    private string EscapeCsv(string? value)
    {
        if (string.IsNullOrEmpty(value))
        {
            return "";
        }

        string escaped = value.Replace("\"", "\"\"");
        return $"\"{escaped}\"";
    }

    private string ProductCategoryPath(JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Inventory_Item_ListOR product)
    {
        List<string> categories = new()
        {
            product.Category1Description,
            product.Category2Description,
            product.Category3Description,
            product.Category4Description,
            product.Category5Description
        };

        return string.Join(" > ", categories.Where(x => !string.IsNullOrWhiteSpace(x)));
    }

    private string FormatCurrencySafe(decimal? value)
    {
        if (value == null)
        {
            return "";
        }

        if (!string.IsNullOrWhiteSpace(Config.LocalCurrency?.RecID))
        {
            return Config.FormattedCurrency(value, Config.LocalCurrency.RecID);
        }

        return value.Value.ToString("0.00", CultureInfo.InvariantCulture);
    }

    private string FormatCustomerSpecificPrice()
    {
        if (IsCustomerPriceLoading)
        {
            return "Loading...";
        }

        if (CustomerSpecificPrice != null)
        {
            return FormatCurrencySafe(CustomerSpecificPrice);
        }

        return string.IsNullOrWhiteSpace(CustomerPriceStatus) ? "Not available" : CustomerPriceStatus;
    }

    private string FormatStockOnHand(JiwaFinancials.Jiwa.JiwaServiceModel.Tables.Or.v_Jiwa_Inventory_Item_ListOR product)
    {
        decimal? stockOnHand = product.InStock ?? product.AvailableStock;
        return Config.FormattedDecimals(stockOnHand, product.QuantityDecimalPlaces, true);
    }

