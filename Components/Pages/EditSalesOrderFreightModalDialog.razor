@attribute [type: RenderModeInteractiveServer]
﻿@using Microsoft.AspNetCore.Components.Forms
@using JiwaCustomerPortal.Components
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using ServiceStack;
@inject NavigationManager NavigationManager
@inject ProtectedLocalStorage ProtectedLocalStore
@inject WebPortalUserSessionStateContainer WebPortalUserSessionStateContainer

<div class="modal fade show" id="myModal" style="display:block; background-color: rgba(10,10,10,.8);"
     aria-modal="true" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">                        
                <h4 class="modal-title">@Title</h4>                
            </div>            

            <div class="modal-body">     
                
                @if (APIRequestInProgress)
                {
                    <div class="modal fade show" id="myModal" style="display:inline-flex" aria-modal="true" role="dialog">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content border-0">
                                <div class="spinner-border" style="width: 3rem; height: 3rem;" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="table-responsive">
                    <table class="table table-bordered table-striped small">
                        <thead>
                            <tr>
                                <th class="text-start">#</th>
                                <th>Ex Tax</th>                                        
                                <th>Tax</th>
                                <th>Inc Tax</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <td class="text-start">Cartage 1</td>
                                <td class="text-end" width="160px">
                                    <input type="number" class="form-control" id="FXCartage1ExGst"                                       
                                           style="text-align: right;"
                                           value="@Config.FormattedDecimals(@salesOrder.FXCartage1ExGst, Config.CurrencyDecimals(salesOrder.CurrencyID), false)"
                                           step="@(Math.Pow(10, (double)-Config.CurrencyDecimals(salesOrder.CurrencyID)))"
                                           min="0"
                                           @onchange="async (e) =>
                                            {
                                                await SalesOrderChanged(e, (q) =>
                                                    {
                                                        decimal value = 0;
                                                        decimal.TryParse(e.Value.ToString(), out value);
                                                        // We don't test the result of the decimal.TryPase - anything invalid is 0
                                                        q.Cartage1ExGst = value;
                                                    });
                                            }">
                                </td>
                                <td class="text-end">@Config.FormattedCurrency(salesOrder.FXCartage1Gst, salesOrder.CurrencyID)</td>
                                <td class="text-end">@Config.FormattedCurrency(salesOrder.FXCartage1ExGst + salesOrder.FXCartage1Gst, salesOrder.CurrencyID)</td>                            
                            </tr>

                            <tr>
                                <td class="text-start">Cartage 2</td>
                                <td class="text-end" width="160px">
                                    <input type="number" class="form-control" id="FXCartage2ExGst"
                                           style="text-align: right;"
                                           value="@Config.FormattedDecimals(@salesOrder.FXCartage2ExGst, Config.CurrencyDecimals(salesOrder.CurrencyID), false)"
                                           step="@(Math.Pow(10, (double)-Config.CurrencyDecimals(salesOrder.CurrencyID)))"
                                           min="0"
                                           @onchange="async (e) =>
                                            {
                                                await SalesOrderChanged(e, (q) => 
                                                    { 
                                                        decimal value = 0;
                                                        decimal.TryParse(e.Value.ToString(), out value);
                                                        // We don't test the result of the decimal.TryPase - anything invalid is 0
                                                        q.Cartage2ExGst = value; 
                                                    });
                                            }">
                                </td>
                                <td class="text-end">@Config.FormattedCurrency(salesOrder.FXCartage2Gst, salesOrder.CurrencyID)</td>
                                <td class="text-end">@Config.FormattedCurrency(salesOrder.FXCartage2ExGst + salesOrder.FXCartage2Gst, salesOrder.CurrencyID)</td>
                            </tr>

                            <tr>
                                <td class="text-start">Cartage 3</td>
                                <td class="text-end" width="160px">
                                    <input type="number" class="form-control" id="FXCartage3ExGst"
                                           style="text-align: right;"
                                           value="@Config.FormattedDecimals(@salesOrder.FXCartage3ExGst, Config.CurrencyDecimals(salesOrder.CurrencyID), false)"
                                           step="@(Math.Pow(10, (double)-Config.CurrencyDecimals(salesOrder.CurrencyID)))"
                                           min="0"
                                           @onchange="async (e) =>
                                            {
                                                await SalesOrderChanged(e, (q) =>
                                                    {
                                                        decimal value = 0;
                                                        decimal.TryParse(e.Value.ToString(), out value);
                                                        // We don't test the result of the decimal.TryPase - anything invalid is 0
                                                        q.Cartage3ExGst = value;
                                                    });
                                            }">
                                </td>
                                <td class="text-end">@Config.FormattedCurrency(salesOrder.FXCartage3Gst, salesOrder.CurrencyID)</td>
                                <td class="text-end">@Config.FormattedCurrency(salesOrder.FXCartage3ExGst + salesOrder.FXCartage3Gst, salesOrder.CurrencyID)</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">                
                <button type="button" class="btn btn-success" @onclick=@ModalOk>OK</button>
            </div>
            <StatusMessage Message="@statusMessage" />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Title { get; set; }
    [Parameter]
    public JiwaFinancials.Jiwa.JiwaServiceModel.SalesOrders.SalesOrder salesOrder { get; set; }
    [Parameter]
    public JiwaFinancials.Jiwa.JiwaServiceModel.SalesOrders.SalesOrderHistory SelectedHistory { get; set; }

    [Parameter]
    public EventCallback<JiwaFinancials.Jiwa.JiwaServiceModel.SalesOrders.SalesOrder> OnClose { get; set; }

    private bool APIRequestInProgress;
    private string? statusMessage;    

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        
        if (WebPortalUserSessionStateContainer.WebPortalUserSession == null)
        {
            // not authenticated ?
            NavigationManager.NavigateTo($"User/SignIn?returnUrl={NavigationManager.Uri}");
            return;
        }        
    }       

    private Task ModalOk()
    {
        return OnClose.InvokeAsync(salesOrder);
    }

    private async Task SalesOrderChanged(ChangeEventArgs e, Action<JiwaFinancials.Jiwa.JiwaServiceModel.SalesOrderPATCHRequest> patchDTOAction)
    {
        JiwaFinancials.Jiwa.JiwaServiceModel.SalesOrderPATCHRequest salesOrderPATCHRequest = new JiwaFinancials.Jiwa.JiwaServiceModel.SalesOrderPATCHRequest();
        salesOrderPATCHRequest.InvoiceID = salesOrder.InvoiceID;
        patchDTOAction.Invoke(salesOrderPATCHRequest);

        int? currentSnap = SelectedHistory.HistoryNo;

        JiwaFinancials.Jiwa.JiwaServiceModel.SalesOrders.SalesOrder response = await SendToAPI<JiwaFinancials.Jiwa.JiwaServiceModel.SalesOrders.SalesOrder>(salesOrderPATCHRequest);
        if (response != null)
        {
            salesOrder = response;
            SelectedHistory = salesOrder.Histories[currentSnap.Value - 1];
        }
    }

    private async Task<TResponse> SendToAPI<TResponse>(IReturn<TResponse> requestDTO)
    {
        bool oldAPIRequestInProgress = APIRequestInProgress;
        APIRequestInProgress = true;

        try
        {
            return await JiwaAPI.SendAsync(requestDTO, WebPortalUserSessionStateContainer.WebPortalUserSession.Id, null);
        }
        catch (ServiceStack.WebServiceException webServiceException)
        {
            if (webServiceException.StatusCode == 401)
            {
                // We are either not authenticated, or our token we have expired, go log on - but first clear any session info as it's no good no more.
                WebPortalUserSessionStateContainer.SetWebPortalUserSession(null);
                NavigationManager.NavigateTo($"User/SignIn?returnUrl={NavigationManager.Uri}");
            }
            else
            {
                statusMessage = webServiceException.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
        finally
        {
            APIRequestInProgress = oldAPIRequestInProgress;
        }

        return default(TResponse);
    }
}
